{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash hooks/bootstrap.sh"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash hooks/check-skill-coverage.sh"
        },
        {
          "type": "command",
          "command": "npx -y tsx hooks/capture-telemetry.ts"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Agent|Task|Write|Edit|Bash|Skill",
      "hooks": [
        {
          "type": "command",
          "command": "npx -y tsx hooks/capture-telemetry.ts"
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "npx -y tsx hooks/capture-telemetry.ts"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "npx -y tsx hooks/maybe-reflect.ts"
        }
      ]
    }
  ],
  "TaskCreated": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "npx -y tsx hooks/agent-team/task-created.ts"
        }
      ]
    }
  ],
  "TaskCompleted": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "npx -y tsx hooks/agent-team/task-completed.ts"
        }
      ]
    }
  ],
  "TeammateIdle": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "npx -y tsx hooks/agent-team/teammate-idle.ts"
        }
      ]
    }
  ]
}
