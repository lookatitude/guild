    "compare": "tsx src/cli.ts compare",
    "run": "tsx src/cli.ts run",
    "serve": "tsx src/cli.ts serve",
    "export-website": "tsx src/cli.ts export-website",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "2.0.0",
    "hono": "4.12.15",
    "yaml": "2.8.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "@vitest/coverage-v8": "2.1.4",
    "fast-check": "3.23.2",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
