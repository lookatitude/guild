{
  "name": "@guild/benchmark",
  "version": "0.1.0-p1",
  "private": true,
  "description": "Guild benchmark factory — fixed cases, repeated runs, six-component guild_score, baseline-vs-candidate compare. P1 import-only.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
